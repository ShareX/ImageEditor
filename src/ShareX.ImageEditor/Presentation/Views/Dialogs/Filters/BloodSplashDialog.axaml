<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="460"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.BloodSplashDialog"
             x:Name="BloodSplashDialogRoot">

    <StackPanel Spacing="0">
        <TextBlock Text="Blood splash" Margin="0,0,0,8"/>

        <StackPanel Spacing="8">
            <controls:EffectSlider Label="Splash amount (%)" ValueStringFormat="{}{0:0}" x:Name="SplashAmountSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="52"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Drip length (%)" ValueStringFormat="{}{0:0}" x:Name="DripLengthSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="48"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Spread (%)" ValueStringFormat="{}{0:0}" x:Name="SpreadSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="42"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Darkness (%)" ValueStringFormat="{}{0:0}" x:Name="DarknessSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="58"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Wet shine (%)" ValueStringFormat="{}{0:0}" x:Name="WetShineSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="30"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button" Content="Cancel" Click="OnCancelClick" Margin="0,0,4,0" HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active" Content="Apply" Click="OnApplyClick" Margin="4,0,0,0" Grid.Column="1" HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
