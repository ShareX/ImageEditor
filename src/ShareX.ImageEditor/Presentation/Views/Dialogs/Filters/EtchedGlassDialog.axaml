<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="460"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.EtchedGlassDialog">

    <StackPanel Spacing="0">
        <TextBlock Text="Etched glass" Margin="0,0,0,8"/>

        <StackPanel Spacing="8">
            <controls:EffectSlider Label="Frost (%)" ValueStringFormat="{}{0:0}" x:Name="FrostSlider"
                                   Minimum="0" Maximum="100" Value="48" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Engrave (%)" ValueStringFormat="{}{0:0}" x:Name="EngraveSlider"
                                   Minimum="0" Maximum="100" Value="68" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Refraction (%)" ValueStringFormat="{}{0:0}" x:Name="RefractionSlider"
                                   Minimum="0" Maximum="100" Value="18" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Highlight (%)" ValueStringFormat="{}{0:0}" x:Name="HighlightSlider"
                                   Minimum="0" Maximum="100" Value="42" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Background fade (%)" ValueStringFormat="{}{0:0}" x:Name="BackgroundFadeSlider"
                                   Minimum="0" Maximum="100" Value="38" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button" Content="Cancel" Click="OnCancelClick" Margin="0,0,4,0" HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active" Content="Apply" Click="OnApplyClick" Margin="4,0,0,0" Grid.Column="1" HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
