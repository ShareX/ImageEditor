<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="460"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.LuminanceContourLinesDialog"
             x:Name="LuminanceContourLinesDialogRoot">

    <StackPanel Spacing="0">
        <TextBlock Text="Luminance Contour Lines" Margin="0,0,0,8"/>

        <StackPanel Spacing="10">
            <controls:EffectSlider Label="Levels" ValueStringFormat="{}{0:0}" x:Name="LevelsSlider"
                                   Minimum="2"
                                   Maximum="64"
                                   Value="12"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Line width" ValueStringFormat="{}{0:0}" x:Name="LineWidthSlider"
                                   Minimum="0"
                                   Maximum="200"
                                   Value="6"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Line strength (%)" ValueStringFormat="{}{0:0}" x:Name="LineStrengthSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="65"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Background strength (%)" ValueStringFormat="{}{0:0}" x:Name="BackgroundStrengthSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="20"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Threshold bias" ValueStringFormat="{}{0:0}" x:Name="ThresholdSlider"
                                   Minimum="0"
                                   Maximum="255"
                                   Value="0"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <StackPanel Spacing="4">
                <TextBlock Text="Line color"/>
                <controls:ColorPickerDropdown x:Name="LineColorPicker"
                                              SelectedColorValue="#FF000000"/>
            </StackPanel>

            <CheckBox x:Name="InvertCheckBox"
                      Content="Invert contour mask"
                      Checked="OnSettingChanged"
                      Unchecked="OnSettingChanged"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button" Content="Cancel" Click="OnCancelClick" Margin="0,0,4,0" HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active" Content="Apply" Click="OnApplyClick" Margin="4,0,0,0" Grid.Column="1" HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
