<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="460"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.OilSlickInterferenceDialog">

    <StackPanel Spacing="0">
        <TextBlock Text="Oil slick interference" Margin="0,0,0,8"/>

        <StackPanel Spacing="8">
            <controls:EffectSlider Label="Intensity (%)" ValueStringFormat="{}{0:0}" x:Name="IntensitySlider"
                                   Minimum="0" Maximum="100" Value="58" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Scale (%)" ValueStringFormat="{}{0:0}" x:Name="ScaleSlider"
                                   Minimum="0" Maximum="100" Value="70" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Darkness (%)" ValueStringFormat="{}{0:0}" x:Name="DarknessSlider"
                                   Minimum="0" Maximum="100" Value="45" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Gloss (%)" ValueStringFormat="{}{0:0}" x:Name="GlossSlider"
                                   Minimum="0" Maximum="100" Value="60" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Hue shift" ValueStringFormat="{}{0:0}°" x:Name="ShiftSlider"
                                   Minimum="0" Maximum="360" Value="0" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button" Content="Cancel" Click="OnCancelClick" Margin="0,0,4,0" HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active" Content="Apply" Click="OnApplyClick" Margin="4,0,0,0" Grid.Column="1" HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
