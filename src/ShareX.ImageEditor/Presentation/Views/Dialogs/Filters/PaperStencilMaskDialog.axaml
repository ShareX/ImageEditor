<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="420"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.PaperStencilMaskDialog"
             x:Name="PaperStencilMaskDialogRoot">

    <StackPanel Spacing="0">
        <TextBlock Text="Paper Stencil Mask" Margin="0,0,0,8"/>

        <StackPanel Spacing="10">
            <controls:EffectSlider Label="Threshold" ValueStringFormat="{}{0:0}" x:Name="ThresholdSlider"
                                   Minimum="0"
                                   Maximum="255"
                                   Value="140"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Feather radius" ValueStringFormat="{}{0:0}" x:Name="FeatherRadiusSlider"
                                   Minimum="0"
                                   Maximum="30"
                                   Value="8"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Edge strength (%)" ValueStringFormat="{}{0:0}" x:Name="EdgeStrengthSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="70"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Background dim (%)" ValueStringFormat="{}{0:0}" x:Name="BackgroundDimSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="35"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <StackPanel Spacing="4">
                <TextBlock Text="Stencil color"/>
                <controls:ColorPickerDropdown x:Name="StencilColorPicker"
                                              SelectedColorValue="#DC000000"/>
            </StackPanel>

            <CheckBox x:Name="InvertMaskCheckBox"
                      Content="Invert mask"
                      Checked="OnSettingChanged"
                      Unchecked="OnSettingChanged"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button" Content="Cancel" Click="OnCancelClick" Margin="0,0,4,0" HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active" Content="Apply" Click="OnApplyClick" Margin="4,0,0,0" Grid.Column="1" HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
