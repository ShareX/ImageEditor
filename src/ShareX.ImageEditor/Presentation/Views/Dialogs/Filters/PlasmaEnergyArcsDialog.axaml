<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="460"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.PlasmaEnergyArcsDialog">

    <StackPanel Spacing="0">
        <TextBlock Text="Plasma energy arcs" Margin="0,0,0,8"/>

        <StackPanel Spacing="8">
            <controls:EffectSlider Label="Energy (%)" ValueStringFormat="{}{0:0}" x:Name="EnergySlider"
                                   Minimum="0" Maximum="100" Value="65" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Arc density (%)" ValueStringFormat="{}{0:0}" x:Name="ArcDensitySlider"
                                   Minimum="0" Maximum="100" Value="46" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Glow (%)" ValueStringFormat="{}{0:0}" x:Name="GlowSlider"
                                   Minimum="0" Maximum="100" Value="70" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Turbulence (%)" ValueStringFormat="{}{0:0}" x:Name="TurbulenceSlider"
                                   Minimum="0" Maximum="100" Value="52" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Thickness (%)" ValueStringFormat="{}{0:0}" x:Name="ThicknessSlider"
                                   Minimum="0" Maximum="100" Value="38" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button" Content="Cancel" Click="OnCancelClick" Margin="0,0,4,0" HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active" Content="Apply" Click="OnApplyClick" Margin="4,0,0,0" Grid.Column="1" HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
