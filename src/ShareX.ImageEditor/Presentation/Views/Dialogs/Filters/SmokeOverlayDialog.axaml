<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="460"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.SmokeOverlayDialog">

    <StackPanel Spacing="0">
        <TextBlock Text="Smoke overlay" Margin="0,0,0,8"/>

        <StackPanel Spacing="8">
            <controls:EffectSlider Label="Density (%)" ValueStringFormat="{}{0:0}" x:Name="DensitySlider"
                                   Minimum="0" Maximum="100" Value="42" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Scale (%)" ValueStringFormat="{}{0:0}" x:Name="ScaleSlider"
                                   Minimum="0" Maximum="100" Value="68" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Drift" ValueStringFormat="{}{0:0}" x:Name="DriftSlider"
                                   Minimum="-100" Maximum="100" Value="18" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Softness (%)" ValueStringFormat="{}{0:0}" x:Name="SoftnessSlider"
                                   Minimum="0" Maximum="100" Value="55" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Contrast (%)" ValueStringFormat="{}{0:0}" x:Name="ContrastSlider"
                                   Minimum="0" Maximum="100" Value="48" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button" Content="Cancel" Click="OnCancelClick" Margin="0,0,4,0" HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active" Content="Apply" Click="OnApplyClick" Margin="4,0,0,0" Grid.Column="1" HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
