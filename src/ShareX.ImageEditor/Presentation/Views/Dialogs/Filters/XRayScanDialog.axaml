<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="460"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.XRayScanDialog">

    <StackPanel Spacing="0">
        <TextBlock Text="X-ray scan" Margin="0,0,0,8"/>

        <StackPanel Spacing="8">
            <controls:EffectSlider Label="Contrast (%)" ValueStringFormat="{}{0:0}" x:Name="ContrastSlider"
                                   Minimum="0" Maximum="100" Value="70" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Glow (%)" ValueStringFormat="{}{0:0}" x:Name="GlowSlider"
                                   Minimum="0" Maximum="100" Value="60" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Edge boost (%)" ValueStringFormat="{}{0:0}" x:Name="EdgeBoostSlider"
                                   Minimum="0" Maximum="100" Value="68" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Scanlines (%)" ValueStringFormat="{}{0:0}" x:Name="ScanlinesSlider"
                                   Minimum="0" Maximum="100" Value="40" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
            <controls:EffectSlider Label="Noise (%)" ValueStringFormat="{}{0:0}" x:Name="NoiseSlider"
                                   Minimum="0" Maximum="100" Value="14" TickFrequency="1" IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button" Content="Cancel" Click="OnCancelClick" Margin="0,0,4,0" HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active" Content="Apply" Click="OnApplyClick" Margin="4,0,0,0" Grid.Column="1" HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
